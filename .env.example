DISCORD_TOKEN=your_discord_bot_token_here

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=discord_bot
# For MongoDB cluster, set as comma-separated list (e.g., mongodb://host1:27017,mongodb://host2:27017)
MONGODB_CLUSTER=

# MariaDB
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_DB_NAME=discord_bot
# For MariaDB cluster, set as comma-separated list of host:port (e.g., host1:3306,host2:3306)
MARIADB_CLUSTER=

# SQLite
SQLITE_DB_PATH=./data/sqlite.db
# For SQLite cluster (not typical, but for replication you might have multiple files)
SQLITE_CLUSTER=

# Default prefix when none is set
DEFAULT_PREFIX=!

# Debug mode
DEBUG=False